#!/bin/bash -eu
# SPDX-FileCopyrightText: 2025 Uwe Fechner
# SPDX-License-Identifier: MIT

_update=false
_skip_subprojects=false
_no_precompile=false
_desired_julia=""
_version_specified=false

_red='\033[31m'
_green='\033[32m'
_reset='\033[0m'

print_usage() {
    echo "Usage:"
    echo "./install"
    echo "./install --update"
    echo "./install --skip-subprojects"
    echo "./install --no-precompile"
    echo "./install +1.11 | +1.12"
    echo "./install --version 1.11 | --version 1.12"
    echo "./install -h"
    echo "./install --help"
    echo "Options:"
    echo "  --update              Run Pkg.update() instead of seeding from .default manifests,"
    echo "                        then copy the resulting main manifest back to *.toml.default."
    echo "  --skip-subprojects    Skip setup/update of examples, test, and docs sub-projects."
    echo "  --no-precompile       Skip all Pkg.precompile() steps; just resolve manifests."
    echo "  +X.Y, --version X.Y   Use Julia channel X.Y for this run (juliaup default unchanged)."
    echo "                        Without this, a menu will ask you to choose 1.11 or 1.12"
    echo "                        (with the currently active Julia version as default)."
    echo "  -h, --help            Show this help message and exit."
}

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -h|--help)
            print_usage
            exit 0
            ;;
        --update)
            _update=true
            shift
            ;;
        --skip-subprojects)
            _skip_subprojects=true
            shift
            ;;
        --no-precompile)
            _no_precompile=true
            shift
            ;;
        --version)
            if [[ $# -lt 2 ]]; then
                echo "Error: --version requires a value (e.g. --version 1.12)"
                exit 1
            fi
            _desired_julia="$2"
            _version_specified=true
            shift 2
            ;;
        +*)
            _desired_julia="${1#+}"
            _version_specified=true
            shift
            ;;
        *)
            echo "Invalid parameter!"
            print_usage
            exit 1
            ;;
    esac
done

if [[ $(basename $(pwd)) == "bin" ]]; then
    cd ..
fi

# Check if juliaup is installed
if ! command -v juliaup &> /dev/null; then
    echo "Error: juliaup is not installed. Please install it first."
    case "$(uname -s)" in
        Linux|Darwin)
            echo "  curl -fsSL https://install.julialang.org | sh -s -- --default-channel 1.11"
            ;;
        MINGW*|MSYS*|CYGWIN*)
            echo "  winget install --name Julia --id 9NJNWW8PVKMN -e -s msstore"
            ;;
        *)
            echo "  See https://github.com/JuliaLang/juliaup for installation instructions."
            ;;
    esac
    exit 1
fi

# If no version specified, show a menu with the current Julia version as default
if [[ -z "$_desired_julia" ]]; then
    # Detect current juliaup default (more reliable than julia --version,
    # which can report a different binary if one is ahead on PATH).
    _current_major=$(juliaup status 2>/dev/null | awk '/\*/ {print $2}')
    if [[ -z "$_current_major" ]]; then
        _current_major="1.12"  # fallback default
    fi

    # Ask user to choose version
    echo "Which Julia version would you like to use?"
    echo ""
    
    if [[ "$_current_major" == "1.11" ]]; then
        echo -e "  ${_green}[1]${_reset} Julia 1.11 (current, default)"
        echo -e "  ${_reset}[2]${_reset} Julia 1.12"
        _default_choice=1
    else
        echo -e "  ${_reset}[1]${_reset} Julia 1.11"
        echo -e "  ${_green}[2]${_reset} Julia 1.12 (current, default)"
        _default_choice=2
    fi
    
    echo ""
    read -p "Choose an option (press Enter for default [$_default_choice]): " _choice
    _choice=${_choice:-$_default_choice}
    
    case "$_choice" in
        1)
            _desired_julia="1.11"
            ;;
        2)
            _desired_julia="1.12"
            ;;
        *)
            echo "Invalid choice. Using default: $_default_choice"
            _desired_julia=$([ "$_default_choice" -eq 1 ] && echo "1.11" || echo "1.12")
            ;;
    esac
else
    # Version was specified via command line
    _current_julia=$(julia --version 2>/dev/null | grep -oE '1\.[0-9]+' | head -1)
    _current_major="${_current_julia%.*}"
fi

echo "Ensuring Julia ${_desired_julia} channel is installed..."
juliaup add "${_desired_julia}"
echo

julia_major="${_desired_julia}"
JULIA="julia +${_desired_julia}"
echo "Using ${JULIA} for this run (juliaup default left unchanged)."

export JULIA_PKG_SERVER_REGISTRY_PREFERENCE=eager

# Delete any existing custom system image for this Julia version
SOFILE="bin/kps-image-${julia_major}.so"
if test -f "$SOFILE"; then
    echo "Deleting old system image: $SOFILE"
    rm -f "$SOFILE"
fi
if compgen -G "bin/kps-image-${julia_major}-*.so" > /dev/null; then
    echo "Deleting legacy branch-specific system images for Julia ${julia_major}"
    rm -f bin/kps-image-"${julia_major}"-*.so
fi

# Only accept Julia 1.11 and 1.12
if [[ $julia_major != "1.11" ]] && [[ $julia_major != "1.12" ]]; then
    echo "Error: Julia $julia_major is not supported. Only Julia 1.11 and 1.12 are supported."
    echo "Re-run with +1.11 or +1.12, e.g. ./bin/install +1.11"
    exit 1
fi

# Copy LocalPreferences if not present
if [ ! -f "LocalPreferences.toml" ]; then
    if [ -f "LocalPreferences.toml.default" ]; then
        cp LocalPreferences.toml.default LocalPreferences.toml
        echo "Copied LocalPreferences.toml.default to LocalPreferences.toml"
    fi
fi

# Delete any generic Manifest.toml and stale 0-byte versioned manifests so
# Pkg resolves from an existing versioned manifest or writes a fresh one.
_prepare_manifests() {
    local dir="${1:-.}"
    rm -f "${dir}/Manifest.toml"
    # Remove stale 0-byte versioned manifests left from failed previous runs
    [ -s "${dir}/Manifest-v1.11.toml" ] || rm -f "${dir}/Manifest-v1.11.toml"
    [ -s "${dir}/Manifest-v1.12.toml" ] || rm -f "${dir}/Manifest-v1.12.toml"
}

if [[ $_update == true ]]; then
    # Update mode: clear existing main manifest for a fresh resolve and run Pkg.update().
    # Skip precompile during update so we can copy the new manifest to .default ASAP
    # (so the user can commit + trigger CI while precompile runs locally afterwards).
    rm -f "Manifest-v${julia_major}.toml"
    _prepare_manifests .
    echo "Updating main project (Pkg.update, no auto-precompile)..."
    JULIA_PKG_PRECOMPILE_AUTO=0 $JULIA --project -e 'using Pkg; Pkg.update()'

    if [ ! -f "Manifest-v${julia_major}.toml" ] && [ -f "Manifest.toml" ]; then
        mv "Manifest.toml" "Manifest-v${julia_major}.toml"
    fi
    cp "Manifest-v${julia_major}.toml" "Manifest-v${julia_major}.toml.default"
    echo "Copied Manifest-v${julia_major}.toml to Manifest-v${julia_major}.toml.default"
    echo "(safe to git commit + push now while precompile continues)"
else
    # Seed the active version's manifest from its .default snapshot.
    if [ -f "Manifest-v${julia_major}.toml.default" ]; then
        cp "Manifest-v${julia_major}.toml.default" "Manifest-v${julia_major}.toml"
        echo "Copied Manifest-v${julia_major}.toml.default to Manifest-v${julia_major}.toml"
    else
        echo -e "${_red}Warning:${_reset} Manifest-v${julia_major}.toml.default not found"
        exit 1
    fi
    _prepare_manifests .

    echo "Instantiating project..."
    JULIA_PKG_PRECOMPILE_AUTO=0 $JULIA --project -e 'using Pkg; Pkg.instantiate()'
fi
if [[ $_no_precompile == true ]]; then
    echo "Skipping main precompile (--no-precompile)."
else
    echo "Precompiling main project..."
    $JULIA --project -e 'using Pkg; Pkg.precompile()'
fi

if [[ $_skip_subprojects == true ]]; then
    echo "Skipping sub-project setup (--skip-subprojects)."
else
    echo "Julia $julia_major: instantiating all sub-projects..."

    # Seed examples/test from the main manifest only on Julia 1.11.
    # On 1.12 we let each sub-project resolve fresh.
    if [[ $julia_major == "1.11" ]]; then
        cp "Manifest-v${julia_major}.toml" "examples/Manifest-v${julia_major}.toml"
        cp "Manifest-v${julia_major}.toml" "test/Manifest-v${julia_major}.toml"
    else
        rm -f examples/Manifest-v${julia_major}.toml test/Manifest-v${julia_major}.toml
    fi
    rm -f docs/Manifest-v${julia_major}.toml

    if [[ $_update == true ]]; then
        _subproj_setup='using Pkg; Pkg.develop(PackageSpec(path=".")); Pkg.resolve(); Pkg.update()'
    else
        _subproj_setup='using Pkg; Pkg.develop(PackageSpec(path=".")); Pkg.resolve(); Pkg.instantiate()'
    fi

    for _sub in examples test docs; do
        _prepare_manifests "$_sub"
        JULIA_PKG_PRECOMPILE_AUTO=0 $JULIA --project="$_sub" -e "$_subproj_setup"
        if [[ $_no_precompile == true ]]; then
            echo "Skipping $_sub precompile (--no-precompile)."
        else
            echo "Precompiling $_sub project..."
            $JULIA --project="$_sub" -e 'using Pkg; Pkg.precompile()'
        fi
            if [[ $julia_major == "1.12" ]]; then
                rm -f examples/Manifest*.toml test/Manifest*.toml docs/Manifest*.toml
                echo "Removed subproject manifests for Julia 1.12"
            fi
    done
fi

# Copy .JETLSConfig.toml.default to .JETLSConfig.toml if it doesn't exist
if [ ! -f ".JETLSConfig.toml" ]; then
    if [ -f ".JETLSConfig.toml.default" ]; then
        cp .JETLSConfig.toml.default .JETLSConfig.toml
        echo "Copied .JETLSConfig.toml.default to .JETLSConfig.toml"
    fi
fi
# If .JETLSConfig.toml exists but but is different from the default, print a warning
if [ -f ".JETLSConfig.toml" ] && [ -f ".JETLSConfig.toml.default" ]; then
    if ! cmp -s .JETLSConfig.toml .JETLSConfig.toml.default; then
        echo -e "${_red}Warning:${_reset} .JETLSConfig.toml already exists and differs from the default. Please review its contents to ensure it is configured correctly."
    fi
fi

# Add alias to shell configuration file
if [[ "$(uname -s)" == "Linux" && -f ~/.bashrc ]]; then
    if ! grep -q "alias jl='bin/run_julia'" ~/.bashrc; then
        echo "alias jl='bin/run_julia'" >> ~/.bashrc
        echo
        echo "Added alias 'jl' to ~/.bashrc"
        echo "Run 'source ~/.bashrc' or restart your terminal to use it"
    fi
elif [[ "$(uname -s)" == "Darwin" ]]; then
    # On macOS, check for zsh (default since Catalina) or bash configuration files
    _config_file=""
    if [[ -f ~/.zshrc ]]; then
        _config_file=~/.zshrc
    elif [[ -f ~/.bash_profile ]]; then
        _config_file=~/.bash_profile
    elif [[ -f ~/.bashrc ]]; then
        _config_file=~/.bashrc
    fi
    
    if [[ -n "$_config_file" ]]; then
        if ! grep -q "alias jl='bin/run_julia'" "$_config_file"; then
            echo "alias jl='bin/run_julia'" >> "$_config_file"
            echo
            echo "Added alias 'jl' to $_config_file"
            echo "Run 'source $_config_file' or restart your terminal to use it"
        fi
    fi
    unset _config_file
fi

echo "Installation complete!"
echo
echo "You can now launch Julia by typing"
echo "cd .."
echo "./bin/run_julia"
